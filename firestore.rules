rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (
          (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
           get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin') ||
          (request.auth.token.role == 'admin')
        );
    }

    function isStaff() {
      return isAuthenticated() &&
        (
          (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
           get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'staff') || 
          isAdmin()
        );
    }

    function hasOnlyAllowedFields(allowedFields) {
      return request.resource.data.keys().hasOnly(allowedFields);
    }

    function hasRequiredFields(requiredFields) {
      return request.resource.data.keys().hasAll(requiredFields);
    }

    function uidNotModified() {
      return !('uid' in request.resource.data) || request.resource.data.uid == resource.data.uid;
    }

    function isValidUser(data) {
      let allowedFields = ['uid', 'name', 'email', 'role', 'status', 'createdAt', 'lastLogin'];
      let requiredFields = ['uid', 'name', 'email', 'role', 'status', 'createdAt'];
      return hasOnlyAllowedFields(allowedFields) &&
             hasRequiredFields(requiredFields) &&
             data.uid is string && data.uid.size() > 0 && data.uid.size() < 100 &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.email is string && data.email.size() < 100 &&
             (data.role == 'staff' || data.role == 'admin') &&
             (data.status == 'active' || data.status == 'inactive') &&
             data.createdAt is timestamp;
    }

    function isValidApplication(data) {
      let allowedFields = [
        'narration', 'tenor', 'nin', 'bvn', 'title', 'surname', 'firstName', 'middleName',
        'gender', 'maritalStatus', 'dateOfBirth', 'countryOfBirth', 'nationality',
        'stateOfOrigin', 'lgaOfOrigin', 'motherMaidenName', 'residentialAddress',
        'nearestBusStop', 'cityTown', 'stateOfResidence', 'occupation', 'phone', 'email',
        'amountNeeded', 'accountNumber', 'bank',
        'nokTitle', 'nokSurname', 'nokFirstName', 'nokMiddleName', 'nokDateOfBirth',
        'nokRelationship', 'nokGender', 'nokPhone', 'nokEmail', 'nokResidentialAddress',
        'nokNearestBusStop', 'nokCityTown', 'nokState', 'nokLga',
        'validIdUrl', 'utilityBillUrl', 'passportPhotoUrl', 'signatureUrl',
        'status', 'createdAt', 'staffAssignedUid', 'notes'
      ];
      let requiredFields = ['nin', 'bvn', 'surname', 'firstName', 'email', 'phone', 'amountNeeded', 'status', 'createdAt'];
      
      return hasOnlyAllowedFields(allowedFields) &&
             hasRequiredFields(requiredFields) &&
             data.nin is string && data.nin.size() >= 10 && data.nin.size() <= 20 &&
             data.bvn is string && data.bvn.size() >= 10 && data.bvn.size() <= 20 &&
             data.surname is string && data.surname.size() > 0 && data.surname.size() < 100 &&
             data.firstName is string && data.firstName.size() > 0 && data.firstName.size() < 100 &&
             data.email is string && data.email.size() < 100 &&
             data.phone is string && data.phone.size() > 0 && data.phone.size() < 50 &&
             data.amountNeeded is number && data.amountNeeded > 0 &&
             (data.status == 'pending' || data.status == 'reviewed' || data.status == 'approved' || data.status == 'rejected') &&
             data.createdAt is timestamp;
    }

    // Audit logs collection - append only
    match /auditLogs/{logId} {
      allow create: if isAuthenticated() && 
                       request.resource.data.userId == request.auth.uid &&
                       request.resource.data.timestamp == request.time &&
                       request.resource.data.action is string &&
                       request.resource.data.collection is string;
      allow read: if isAdmin();
      allow update, delete: if false; // Never allow modifications to audit logs
    }

    // Users collection
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && isValidUser(request.resource.data) && 
                       (
                         // Admin can create any staff member
                         (isAdmin() && request.resource.data.role == 'staff') ||
                         // Users can only create themselves as staff (will need admin approval)
                         (isOwner(userId) && request.resource.data.role == 'staff' && request.resource.data.status == 'active')
                       );
      allow update: if isAuthenticated() && isValidUser(request.resource.data) && uidNotModified() &&
                       (
                         // Users can only update their own profile (role/status unchanged)
                         (isOwner(userId) && request.resource.data.role == resource.data.role && request.resource.data.status == resource.data.status) ||
                         // Admin can update any user
                         isAdmin()
                       );
      allow delete: if isAdmin();
    }

    // Applications collection
    match /applications/{applicationId} {
      allow read: if isStaff() && 
                     (
                       // Users can read their own applications
                       resource.data.submittedByEmail == request.auth.token.email ||
                       // Staff assigned to the application can read it
                       resource.data.staffAssignedUid == request.auth.uid ||
                       // Admins can read all
                       isAdmin()
                     );
      
      allow create: if isValidApplication(request.resource.data) && 
                       request.resource.data.status == 'pending' &&
                       request.resource.data.createdAt == request.time;
      
      allow update: if isStaff() && 
                       isValidApplication(request.resource.data) &&
                       (
                         // Staff can only update status and notes on their assigned applications
                         (resource.data.staffAssignedUid == request.auth.uid && 
                          request.resource.data.status in ['pending', 'reviewed', 'approved', 'rejected']) ||
                         // Admin can update everything
                         isAdmin()
                       );
      
      allow delete: if isAdmin();
    }

    // Application notes - for staff comments
    match /applicationNotes/{noteId} {
      allow read: if isStaff();
      allow create: if isAuthenticated() &&
                       isStaff() &&
                       request.resource.data.staffId == request.auth.uid &&
                       request.resource.data.applicationId is string &&
                       request.resource.data.note is string &&
                       request.resource.data.createdAt == request.time;
      allow update, delete: if isOwner(resource.data.staffId) || isAdmin();
    }
  }
}
